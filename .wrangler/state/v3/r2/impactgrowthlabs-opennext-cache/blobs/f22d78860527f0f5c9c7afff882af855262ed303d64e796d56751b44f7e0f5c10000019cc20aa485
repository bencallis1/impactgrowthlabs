82q1h\"}},\"id\":\"50c0Fu5BN6zrXM5o9Fdpqz\",\"type\":\"Entry\",\"createdAt\":\"2026-03-01T20:29:30.229Z\",\"updatedAt\":\"2026-03-01T20:37:07.652Z\",\"environment\":{\"sys\":{\"id\":\"master\",\"type\":\"Link\",\"linkType\":\"Environment\"}},\"publishedVersion\":21,\"revision\":2,\"contentType\":{\"sys\":{\"type\":\"Link\",\"linkType\":\"ContentType\",\"id\":\"teamMember\"}},\"locale\":\"en-US\"},\"fields\":{\"name\":\"Benjamin Callis\",\"bio\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Ben Callis is a visionary technical founder and CEO whose grit and determination are second to none. \",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Before founding Ivy House, Callis made a name for himself by playing a critical role in shaping several successful startups' product strategies and designs in the mortgage, business intelligence, and education sectors. \",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"His expertise in these areas is evident in the accolades and achievements of the companies he has worked with.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Callis is highly skilled with an education from the prestigious MIT and Sloan School of Management. He has also completed several cohorts at the Stanford D school, further honing his skills in design and innovation.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"But Callis's contributions to the industry go far beyond his professional accomplishments.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"He is passionate about teaching and mentoring, teaching coding and UX design to over 5,000 students. He is also actively engaged in cultivating new talent by sharing his knowledge and network.\\\"\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"email\":\"ben@impactgrowthlabs.com\",\"role\":\"Founder\",\"photo\":{\"metadata\":{\"tags\":[],\"concepts\":[]},\"sys\":{\"space\":{\"sys\":{\"type\":\"Link\",\"linkType\":\"Space\",\"id\":\"lp5y22r82q1h\"}},\"id\":\"4LXcqB6AJoWsdoJ1OSHFov\",\"type\":\"Asset\",\"createdAt\":\"2026-03-01T20:25:58.758Z\",\"updatedAt\":\"2026-03-01T20:25:58.758Z\",\"environment\":{\"sys\":{\"id\":\"master\",\"type\":\"Link\",\"linkType\":\"Environment\"}},\"publishedVersion\":8,\"revision\":1,\"locale\":\"en-US\"},\"fields\":{\"title\":\"Benjamin Callis Avatar\",\"description\":\"Profile picture of Benajmin Callis\",\"file\":{\"url\":\"//images.ctfassets.net/lp5y22r82q1h/4LXcqB6AJoWsdoJ1OSHFov/89da91778edd6f2d719c0c8be5ac1ea6/1312.jpeg\",\"details\":{\"size\":38274,\"image\":{\"width\":512,\"height\":512}},\"fileName\":\"1312.jpeg\",\"contentType\":\"image/jpeg\"}}},\"linkedIn\":\"https://www.linkedin.com/in/benjamincallis\",\"sortOrder\":1,\"featured\":true,\"slug\":\"benjamin-callis\",\"memberType\":\"Founder\"}},\"excerpt\":\"The Risk-Return-Impact (RRI) model emerged from a simple observation: the businesses generating the highest returns in our portfolio were also creating the most measurable positive change. Not sometimes. Consistently.\",\"body\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"What the Model Reveals\",\"nodeType\":\"text\"}],\"nodeType\":\"heading-3\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Traditional business frameworks optimize for two variables: minimizing risk while maximizing returns. Impact gets treated as a separate consideration—something you add later, or trade off against profitability.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"The RRI model integrates a third dimension: measurable impact becomes a leading indicator of long-term value creation.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Here's why this matters:\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"When you solve real problems for real people, you create:\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Stronger product-market fit\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" (you're addressing genuine needs)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Higher customer retention\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" (your solution meaningfully improves lives)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Better talent acquisition\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" (people want to work on things that matter)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Reduced regulatory risk\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" (you're aligned with where policy is heading)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Premium pricing power\",\"nodeType\":\"text\"},{\"data\":{},\"marks\":[],\"value\":\" (customers value transformative solutions)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"}],\"nodeType\":\"unordered-list\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"These aren't abstract benefits. They show up in unit economics, growth rates, and exit multiples.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"The Three Components\",\"nodeType\":\"text\"}],\"nodeType\":\"heading-3\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Risk Assessment\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Traditional risk factors plus impact-specific considerations:\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Mission drift risk (can you maintain impact at scale?)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Measurement complexity (can you verify your impact claims?)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Market timing (is the ecosystem ready for your solution?)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"},{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Capital alignment (will future investors support your mission?)\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"list-item\"}],\"nodeType\":\"unordered-list\"},{\"data\":{},\"content\":[{\"data\":{},\"marks\":[{\"type\":\"bold\"}],\"value\":\"Return Modeling\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"},{\"data\":{},\"con